# MailHaven production configuration
# Copia questo file in .env e genera valori nuovi per ogni ambiente.

NODE_ENV=production
PORT=3001

# URL pubblico usato dal browser e dagli OAuth callback.
APP_URL=https://mailhaven.example.com
OAUTH_REDIRECT_BASE_URL=https://mailhaven.example.com
ADDITIONAL_ORIGINS=

# Segreti: genera con openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars
ENCRYPTION_KEY=replace_with_64_hex_chars

# Database interno Docker
DB_HOST=mailhaven-db
DB_PORT=5432
DB_NAME=mailhaven
DB_USER=mailhaven
DB_PASSWORD=replace_with_strong_password

# SMTP per notifiche di sicurezza, opzionale
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# OAuth, opzionale
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VIRUSTOTAL_API_KEY=
GITHUB_TOKEN=

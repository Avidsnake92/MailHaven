# MailVault Configuration
HOST_IP=192.168.0.66

# JWT Secret (genera con: openssl rand -hex 32)
JWT_SECRET=cambia_questa_chiave

# Database MailVault (database separato da OpenArchiver)
DB_HOST=mailvault-db
DB_PORT=5432
DB_NAME=mailvault
DB_USER=mailvault
DB_PASSWORD=cambia_questa_password

# OpenArchiver API
OPENARCHIVER_API_URL=http://192.168.0.66:3000
OPENARCHIVER_EMAIL=admin@admin.it
OPENARCHIVER_PASSWORD=la_tua_password_openarchiver

# SMTP per notifiche di sicurezza
SMTP_HOST=mail.tuodominio.it
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifiche@tuodominio.it
SMTP_PASS=tuapassword

<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:type="MailApp">

  <Id>6d8b4b57-b0d5-4b56-8590-ec7c1f2c8e89</Id>
  <Version>1.0.0</Version>
  <ProviderName>K2Tech</ProviderName>
  <DefaultLocale>it-IT</DefaultLocale>
  <DisplayName DefaultValue="MailHaven Archive"/>
  <Description DefaultValue="Accedi all'archivio email MailHaven e ripristina messaggi eliminati direttamente da Outlook."/>
  <IconUrl DefaultValue="MAILVAULT_URL/logo.svg"/>
  <HighResolutionIconUrl DefaultValue="MAILVAULT_URL/logo.svg"/>
  <SupportUrl DefaultValue="https://k2tech.it"/>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="MAILVAULT_URL/plugin/outlook/panel.html"/>
        <RequestedHeight>500</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

</OfficeApp>

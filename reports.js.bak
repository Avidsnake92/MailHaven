const router = require('express').Router();
const { authMiddleware, requireRole } = require('../middleware/auth');
const { getSmtpConfig, getTransport } = require('../services/mailer');
const { ERRORS, AppError } = require('../errors');

const NOTIFY_EMAIL = 'andrea.terraneo@k2tech.it';

const requireSuperadmin = [authMiddleware, requireRole('superadmin')];

// ── Controlla se SMTP è configurato ──
const isSmtpConfigured = async (db) => {
  try {
    const cfg = await getSmtpConfig(db);
    return !!(cfg.host && cfg.user && cfg.pass);
  } catch { return false; }
};

// ── Invia notifica email ──
const sendNotification = async (db, subject, html) => {
  try {
    const cfg = await getSmtpConfig(db);
    if (!cfg.host || !cfg.user || !cfg.pass) return;
    const transport = getTransport(cfg);
    await transport.sendMail({
      from: `"MailHaven Reports" <${cfg.user}>`,
      to: NOTIFY_EMAIL,
      subject,
      html,
    });
  } catch (e) {
    console.error('[Reports] Email notification error:', e.message);
  }
};

// GET /reports/smtp-status — controlla se SMTP è configurato
router.get('/smtp-status', authMiddleware, async (req, res) => {
  const configured = await isSmtpConfigured(req.app.locals.db);
  res.json({ configured });
});

// GET /reports — lista segnalazioni
router.get('/', authMiddleware, async (req, res, next) => {
  const db = req.app.locals.db;
  const user = req.user;
  const { status, type, page = 1, limit = 20 } = req.query;
  const offset = (parseInt(page) - 1) * parseInt(limit);
  try {
    let where = [], params = [], i = 1;
    if (user.role !== 'superadmin') { where.push(`r.user_id = $${i++}`); params.push(user.id); }
    if (status) { where.push(`r.status = $${i++}`); params.push(status); }
    if (type) { where.push(`r.type = $${i++}`); params.push(type); }
    const whereStr = where.length ? 'WHERE ' + where.join(' AND ') : '';
    const [reports, count] = await Promise.all([
      db.query(`
        SELECT r.id, r.type, r.status, r.priority, r.title, r.description, r.page_url,
               r.created_at, r.updated_at,
               u.email as user_email, u.full_name as user_name,
               (SELECT COUNT(*) FROM report_messages rm WHERE rm.report_id = r.id) as message_count,
               (SELECT rm.created_at FROM report_messages rm WHERE rm.report_id = r.id ORDER BY rm.created_at DESC LIMIT 1) as last_message_at
        FROM reports r JOIN users u ON r.user_id = u.id
        ${whereStr} ORDER BY r.updated_at DESC LIMIT $${i++} OFFSET $${i++}
      `, [...params, parseInt(limit), offset]),
      db.query(`SELECT COUNT(*) FROM reports r ${whereStr}`, params),
    ]);
    res.json({ reports: reports.rows, total: parseInt(count.rows[0].count), page: parseInt(page), pages: Math.ceil(parseInt(count.rows[0].count) / parseInt(limit)) });
  } catch (err) { next(new AppError(ERRORS.MH_1903, err.message)); }
});

// POST /reports — crea nuova segnalazione
router.post('/', authMiddleware, async (req, res, next) => {
  const db = req.app.locals.db;
  const user = req.user;
  const { type, title, description, page_url } = req.body;
  if (!type || !description) return next(new AppError(ERRORS.MH_1402, 'tipo e descrizione obbligatori'));
  try {
    const result = await db.query(`
      INSERT INTO reports (user_id, type, title, description, page_url, status, priority)
      VALUES ($1, $2, $3, $4, $5, 'open', 'normal') RETURNING *
    `, [user.id, type, title || description.slice(0, 80), description, page_url || null]);
    const report = result.rows[0];
    await sendNotification(db,
      `[MailHaven] Nuova segnalazione: ${type.toUpperCase()} — ${report.title}`,
      `<div style="font-family:sans-serif;max-width:600px;margin:0 auto">
        <h2 style="color:#2563eb">Nuova segnalazione ricevuta</h2>
        <table style="width:100%;border-collapse:collapse;margin:16px 0">
          <tr><td style="padding:8px;background:#f9fafb;font-weight:bold;width:120px">Da</td><td style="padding:8px">${user.full_name || user.email}</td></tr>
          <tr><td style="padding:8px;background:#f9fafb;font-weight:bold">Tipo</td><td style="padding:8px">${type}</td></tr>
          <tr><td style="padding:8px;background:#f9fafb;font-weight:bold">Titolo</td><td style="padding:8px">${report.title}</td></tr>
          ${page_url ? `<tr><td style="padding:8px;background:#f9fafb;font-weight:bold">Pagina</td><td style="padding:8px">${page_url}</td></tr>` : ''}
        </table>
        <div style="background:#f9fafb;border-left:4px solid #2563eb;padding:16px;margin:16px 0">
          <p style="margin:0;white-space:pre-wrap">${description}</p>
        </div>
        <p style="color:#6b7280;font-size:12px">MailHaven Reports — ID: ${report.id}</p>
      </div>`
    );
    res.json(report);
  } catch (err) { next(new AppError(ERRORS.MH_1903, err.message)); }
});

// GET /reports/:id — dettaglio + messaggi
router.get('/:id', authMiddleware, async (req, res, next) => {
  const db = req.app.locals.db;
  const user = req.user;
  try {
    const report = await db.query(`
      SELECT r.*, u.email as user_email, u.full_name as user_name
      FROM reports r JOIN users u ON r.user_id = u.id WHERE r.id = $1
    `, [req.params.id]);
    if (!report.rows.length) return next(new AppError(ERRORS.MH_1401, `report_id: ${req.params.id}`));
    const r = report.rows[0];
    if (user.role !== 'superadmin' && r.user_id !== user.id) return next(new AppError(ERRORS.MH_1003));
    const messages = await db.query(`
      SELECT rm.*, u.full_name as sender_name, u.email as sender_email, u.role as sender_role
      FROM report_messages rm JOIN users u ON rm.user_id = u.id
      WHERE rm.report_id = $1 ORDER BY rm.created_at ASC
    `, [req.params.id]);
    res.json({ ...r, messages: messages.rows });
  } catch (err) { next(err instanceof AppError ? err : new AppError(ERRORS.MH_1903, err.message)); }
});

// POST /reports/:id/messages — invia messaggio nel thread
router.post('/:id/messages', authMiddleware, async (req, res, next) => {
  const db = req.app.locals.db;
  const user = req.user;
  const { message } = req.body;
  if (!message) return next(new AppError(ERRORS.MH_1402, 'messaggio obbligatorio'));
  try {
    const report = await db.query('SELECT * FROM reports WHERE id = $1', [req.params.id]);
    if (!report.rows.length) return next(new AppError(ERRORS.MH_1401));
    const r = report.rows[0];
    if (user.role !== 'superadmin' && r.user_id !== user.id) return next(new AppError(ERRORS.MH_1003));
    const result = await db.query(`
      INSERT INTO report_messages (report_id, user_id, message, is_staff)
      VALUES ($1, $2, $3, $4) RETURNING *
    `, [req.params.id, user.id, message, user.role === 'superadmin']);
    await db.query('UPDATE reports SET updated_at = NOW() WHERE id = $1', [req.params.id]);
    const isSuperadmin = user.role === 'superadmin';
    await sendNotification(db,
      `[MailHaven] ${isSuperadmin ? 'Risposta staff' : 'Nuovo messaggio'} su: ${r.title}`,
      `<div style="font-family:sans-serif;max-width:600px;margin:0 auto">
        <h2 style="color:${isSuperadmin ? '#16a34a' : '#2563eb'}">${isSuperadmin ? '📬 Risposta dello staff' : '💬 Nuovo messaggio utente'}</h2>
        <p><strong>Segnalazione:</strong> ${r.title} (${r.type})</p>
        <p><strong>Da:</strong> ${user.full_name || user.email}</p>
        <div style="background:#f9fafb;border-left:4px solid ${isSuperadmin ? '#16a34a' : '#2563eb'};padding:16px;margin:16px 0">
          <p style="margin:0;white-space:pre-wrap">${message}</p>
        </div>
        <p style="color:#6b7280;font-size:12px">ID: ${r.id}</p>
      </div>`
    );
    res.json(result.rows[0]);
  } catch (err) { next(err instanceof AppError ? err : new AppError(ERRORS.MH_1903, err.message)); }
});

// PATCH /reports/:id — aggiorna stato/priorità (solo superadmin)
router.patch('/:id', ...requireSuperadmin, async (req, res, next) => {
  const db = req.app.locals.db;
  const { status, priority } = req.body;
  try {
    const result = await db.query(`
      UPDATE reports SET status = COALESCE($1, status), priority = COALESCE($2, priority), updated_at = NOW()
      WHERE id = $3 RETURNING *
    `, [status || null, priority || null, req.params.id]);
    if (!result.rows.length) return next(new AppError(ERRORS.MH_1401));
    res.json(result.rows[0]);
  } catch (err) { next(new AppError(ERRORS.MH_1903, err.message)); }
});

module.exports = router;
